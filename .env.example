# The app runs with ZERO configuration: local session auth + an in-memory demo
# dataset, no database or external auth provider. Everything below is OPTIONAL —
# only fill in what you actually want to enable (payments, email, cron).

# --- Auth -----------------------------------------------------------------
# Secret used to sign the session cookie (HMAC). Optional in the demo — a stable
# built-in default is used if unset. Set a long random string in production so
# forged cookies signed with the well-known default are rejected.
AUTH_SECRET=

# --- Stripe ---------------------------------------------------------------
# Test keys in development. Webhook secret comes from `stripe listen`.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (transactional email) ----------------------------------------
# Optional in dev — emails will be skipped (logged only) if this is empty.
RESEND_API_KEY=
EMAIL_FROM="BraidFlow <hello@yourdomain.com>"

# --- Cron -----------------------------------------------------------------
# Any random string. Vercel Cron sends this as a Bearer token.
CRON_SECRET=replace-with-a-long-random-string
# Minutes an unpaid (pending_payment) booking may sit before the expiry cron
# cancels it and releases the slot. Optional — defaults to 30.
PENDING_BOOKING_TTL_MINUTES=30

# --- App ------------------------------------------------------------------
# Public base URL. Used for absolute links (emails, sitemap, OpenGraph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Error monitoring (Sentry) --------------------------------------------
# All optional. With no DSN, Sentry is completely inert and the app behaves
# exactly as without it. Create a project at sentry.io to get a DSN.
# NEXT_PUBLIC_SENTRY_DSN is read on both client and server; SENTRY_DSN can
# override the server-side DSN if you want them to differ.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Performance trace sampling (0–1). Default 0.1. Lower to reduce volume/cost.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Only needed to upload source maps during `next build` (for readable stack
# traces). Find org/project slugs and create a token in your Sentry settings.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
